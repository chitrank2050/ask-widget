{
  "name": "ask-widget",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "homepage": "https://www.chitrankagnihotri.com",
  "author": {
    "name": "Chitrank agnihotri",
    "email": "chitrank2050@gmail.com",
    "url": "https://wwww.chitrankagnihotri.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/chitrank2050/ask-widget"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "menu": "node scripts/menu.mjs",
    "init": "./scripts/install.sh",
    "obliviate": "node scripts/menu.mjs obliviate",
    "obliviate:full": "./scripts/obliviate.sh",
    "clean-setup": "pnpm run obliviate && pnpm run init",
    "clean-build": "pnpm run obliviate && pnpm run init && ./scripts/build.sh",
    "git": "node scripts/menu.mjs git",
    "git-tag": "./scripts/git-tag.sh",
    "git-release": "./scripts/git-release.sh",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@clack/prompts": "^1.1.0",
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "picocolors": "^1.1.1",
    "prettier": "^3.8.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^8.0.0",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.0"
  },
  "lint-staged": {
    "**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "**/*.{json,md,css}": [
      "prettier --write"
    ]
  }
}
